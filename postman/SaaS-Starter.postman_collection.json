    {
      "name": "Invitations",
      "item": [
        {
          "name": "Create Invitation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.environment.set('invitation_token', json.token);",
                  "}",
                  "if (json.id) {",
                  "  pm.environment.set('invitation_id', String(json.id));",
                  "}",
                  "if (json.email) {",
                  "  pm.environment.set('invitation_email', json.email);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Tenant-ID",
                "value": "{{tenant_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{invitation_email}}\",\n  \"role\": \"member\"\n}"
            },
            "url": "{{base_url}}/api/v1/invitations"
          }
        },
        {
          "name": "Preview Invitation",
          "request": {
            "method": "GET",
            "auth": {
              "type": "noauth"
            },
            "url": "{{base_url}}/api/v1/invitations/{{invitation_token}}"
          }
        },
        {
          "name": "Accept Invitation",
          "request": {
            "method": "POST",
            "auth": {
              "type": "noauth"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{invited_name}}\",\n  \"password\": \"{{invited_password}}\"\n}"
            },
            "url": "{{base_url}}/api/v1/invitations/{{invitation_token}}/accept"
          }
        },
        {
          "name": "Revoke Invitation",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "X-Tenant-ID",
                "value": "{{tenant_id}}"
              }
            ],
            "url": "{{base_url}}/api/v1/invitations/{{invitation_id}}"
          }
        }
      ]
    },
