{
  "info": {
    "name": "SaaS Starter API",
    "_postman_id": "7c6f6ce4-98f8-4f80-ae28-7eb0fd7ab001",
    "description": "Collection for SaaS Starter v1 APIs (auth, tenant, membership, project, billing).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo User\",\n  \"email\": \"demo.user@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}"
            },
            "url": "{{base_url}}/api/v1/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.environment.set('auth_token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\"\n}"
            },
            "url": "{{base_url}}/api/v1/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/logout"
          }
        }
      ]
    },
    {
      "name": "API Tokens",
      "item": [
        {
          "name": "List Tokens",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/tokens"
          }
        },
        {
          "name": "Create Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.environment.set('api_token', json.token);",
                  "}",
                  "",
                  "// If the API returns only the token string, you still need token id",
                  "// to revoke it. Get it from 'List Tokens' response.",
                  ""
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"postman\",\n  \"abilities\": [\"*\"]\n}"
            },
            "url": "{{base_url}}/api/v1/tokens"
          }
        },
        {
          "name": "Revoke Token",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/tokens/{{api_token_id}}"
          }
        }
      ]
    },
